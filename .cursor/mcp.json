{
  "mcpServers": {
    "onboarding-copilot": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--no-sync",
        "--project",
        "${workspaceFolder}",
        "python",
        "-m",
        "ob.mcp_server"
      ],
      "env": {
        "OB_PROFILE": "profiles/scikit-image.yaml"
      }
    }
  }
}
